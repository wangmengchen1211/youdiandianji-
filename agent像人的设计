  "situation_type": "possible_cognitive_decline",
  "secondary_types": [
    "caregiver_anxiety",
    "parent_child_relationship"
  ],
  "risk_level": "medium_high",
  "explicit_need": "用户怀疑妈妈出现认知下降",
  "implicit_needs": [
    "需要判断哪些现象值得重视",
    "需要把模糊担忧转化为可观察记录",
    "需要学习如何不伤害妈妈自尊地沟通",
    "需要知道是否应该建议就医评估",
    "需要被理解照护压力"
  ],
  "missing_information": [
    "用户是通过哪些具体行为发现的",
    "变化是突然还是逐渐发生",
    "是否影响日常生活和安全",
    "妈妈自己是否意识到变化",
    "用户和妈妈谈这件事时是否容易冲突"
  ],
  "recommended_strategy": "ask_targeted_questions_before_advice",
  "forbidden_response": [
    "不能说妈妈就是老年痴呆",
    "不能只说我理解你很担心",
    "不能直接跳到设置提醒",
    "不能提供诊断结论"
  ]
}
```

