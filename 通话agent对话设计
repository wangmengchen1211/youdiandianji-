## 10. 通话阶段推进规则

### 10.1 阶段列表

```text
identity
warm_greeting
child_update
light_care
task_reminder
task_confirmation
relay_back
closing
```

---

### 10.2 阶段推进逻辑

```ts
function decideNextStage(state, analysis) {
  if (state.current_stage === "identity") {
    return "warm_greeting";
  }

  if (state.current_stage === "warm_greeting" && analysis.stage_completion.completed) {
    return "child_update";
  }

  if (state.current_stage === "child_update" && analysis.stage_completion.completed) {
    return "light_care";
  }

  if (state.current_stage === "light_care") {
    if (state.probe_budget.health_remaining > 0 && !state.task_slots.general_condition) {
      return "light_care";
    }
    return "task_reminder";
  }

  if (state.current_stage === "task_reminder") {
    return "task_confirmation";
  }

  if (state.current_stage === "task_confirmation") {
    if (state.task_slots.medication_taken !== null) {
      return "relay_back";
    }
    return "task_confirmation";
  }

  if (state.current_stage === "relay_back") {
    return "closing";
  }

  return "closing";
}
```

