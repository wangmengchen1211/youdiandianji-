## 17. 代码伪实现

### 17.1 turn handler

```ts
async function handleCallTurn(sessionId: string, elderText: string) {
  const session = await callSessionRepo.get(sessionId);
  const state = session.conversationState;
  const context = await relationshipContextLoader.load(session);

  const plannerResult = await proactiveConversationAgent.planNextTurn({
    elderText,
    callPlan: session.callPlan,
    conversationState: state,
    elderProfile: context.elderProfile,
    caregiverProfile: context.caregiverProfile,
    relationshipMemory: context.relationshipMemory,
    recentCallSummaries: context.recentCallSummaries,
  });

  const newState = mergeConversationState(
    state,
    plannerResult.state_patch,
    {
      current_stage: plannerResult.next.stage,
      last_elder_utterance: elderText,
      last_assistant_utterance: plannerResult.next.assistant_text,
      turn_count: state.turn_count + 1
    }
  );

  await callSessionRepo.appendTranscript(sessionId, {
    elder: elderText,
    assistant: plannerResult.next.assistant_text
  });

  await callSessionRepo.updateState(sessionId, newState);

  if (plannerResult.memory_candidates?.length) {
    await memoryRepo.saveCandidates(plannerResult.memory_candidates);
  }

  return {
    assistantText: plannerResult.next.assistant_text,
    stage: plannerResult.next.stage,
    isCallEnding: plannerResult.next.is_call_ending,
    state: newState
  };
}
```

