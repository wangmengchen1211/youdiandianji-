# ───── 必需 ─────
# DeepSeek LLM（对话、状态机、记忆抽取都依赖）
DEEPSEEK_API_KEY=sk-xxx
# 可选：默认 deepseek-chat
DEEPSEEK_MODEL=deepseek-chat

# ───── TTS（语音电话提醒）三选一 ─────
# 优先级：TTS_PROVIDER 显式指定 > MINIMAX > VOLC > AZURE
# 没有任何 TTS key 时，电话提醒会自动降级为浏览器原生 SpeechSynthesis
# TTS_PROVIDER=minimax  # 可选：minimax / volcano / azure

# 方案 A：MiniMax（MiniMax 网关）
MINIMAX_API_KEY=
MINIMAX_VOICE=female-shaonv
# MINIMAX_TTS_URL=https://tokendance.space/gateway/minimax/v1/t2a_v2
# MINIMAX_MODEL=minimax-speech-2.8-turbo

# 方案 B：火山引擎 TTS
VOLC_APPID=
VOLC_ACCESS_TOKEN=
# VOLC_VOICE=zh_female_wanxiang_moon_bigtts
# VOLC_CLUSTER=volcano_tts

# 方案 C：Azure TTS
AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=eastasia

# ───── 可选 ─────
# OCR 服务（仅本地开发支持；Vercel 部署后 OCR 功能自动降级）
# OCR_SERVICE_URL=http://127.0.0.1:8765
